generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  phone        String        @unique  // Sekarang nomor HP yang menjadi unik
  password     String
  name         String
  role         String        @default("STAFF")
  bca          String?
  seabank      String?
  gopay        String?
  dana         String?
  transactions Transaction[]
  createdAt    DateTime      @default(now())
}

model Transaction {
  id          String   @id @default(cuid())
  amount      Float
  type        String
  category    String?
  date        DateTime
  note        String?
  isReimburse Boolean  @default(false)
  status      String   @default("COMPLETED")
  transferProof String?
  receiptImage  String?
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())
}