generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  role         String        @default("STAFF") // STAFF atau ADMIN
  transactions Transaction[]
}

model Transaction {
  id          String   @id @default(cuid())
  amount      Float
  type        String   // "INCOME" atau "EXPENSE"
  category    String?  // Sumber dana atau Kategori pengeluaran
  date        DateTime
  note        String?
  isReimburse Boolean  @default(false)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())
}